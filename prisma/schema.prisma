generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Model User ───────────────────────────────────────────

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relasi: satu user memiliki banyak task
  tasks Task[]

  @@map("users") // Nama tabel di database: "users"
}

// ─── Model Category ───────────────────────────────────────

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  color     String   @default("#6366F1")
  createdAt DateTime @default(now())

  // Relasi: satu kategori memiliki banyak task
  tasks Task[]

  @@map("categories")
}

// ─── Model Task ───────────────────────────────────────────

model Task {
  id          Int       @id @default(autoincrement())
  title       String
  description String?   // Tanda ? berarti nullable/opsional
  status      Status    @default(TODO)
  priority    Priority  @default(MEDIUM)
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Foreign Keys
  userId     Int
  categoryId Int? // Nullable — task boleh tidak punya kategori

  // Relasi (Prisma menyimpan join logic)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  category Category? @relation(fields: [categoryId], references: [id])

  // Index untuk mempercepat query filter
  @@index([userId])
  @@index([status])
  @@index([userId, status]) // Composite index

  @@map("tasks")
}

// ─── Enumerasi ────────────────────────────────────────────

enum Status {
  TODO
  IN_PROGRESS
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}